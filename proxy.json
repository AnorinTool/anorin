<?php

header('Content-Type: application/json; charset=utf-8');

$mode = isset($_GET['mode']) ? (int)$_GET['mode'] : 1;

if ($mode < 1 || $mode > 13) {
    $mode = 1;
}

$base = "https://5g142.wiremockapi.cloud/menu/";
$url = $base . $mode;

// cURL
$ch = curl_init($url);
curl_setopt_array($ch, [
    CURLOPT_RETURNTRANSFER => true,
    CURLOPT_TIMEOUT => 10,
]);

$response = curl_exec($ch);
$err = curl_error($ch);
curl_close($ch);

// lỗi request
if (!$response) {
    echo json_encode([
        "status" => "error",
        "message" => "cannot load menu",
        "debug" => $err
    ], JSON_UNESCAPED_UNICODE);
    exit;
}

/*
  CHUẨN HÓA OUTPUT JSON
  - không trả raw text trực tiếp
*/
echo json_encode([
    "status" => "success",
    "mode" => $mode,
    "menu" => $response
], JSON_UNESCAPED_UNICODE);
